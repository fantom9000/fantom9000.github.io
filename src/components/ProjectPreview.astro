---
import type { Project } from "@data/projects";

type Props = {
  project: Project;
};

const { project } = Astro.props;
---

<article class="project-preview" data-project={project.slug}>
  {project.number === "01" && <span class="project-kicker">Задизайнил</span>}
  <div class="project-sidebar">
    <div class="project-sidebar__meta">
      <span class="project-number">{project.number}</span>
      <div class="project-sidebar__text">
        <h2><a href={project.href}>{project.title}</a></h2>
        <p>{project.description}</p>
      </div>
    </div>
  </div>
  <a class="project-visual" href={project.href} aria-label={`Открыть проект ${project.title}`}>
    <img src={project.previewImage} alt={project.description} width="1086" height="724" loading={project.number === "01" ? "eager" : "lazy"} />
  </a>
</article>
